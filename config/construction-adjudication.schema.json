{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://canto-span.local/schemas/construction-adjudication-v1.json",
  "title": "Canto Span construction adjudications",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "adjudicated_on", "records"],
  "properties": {
    "schema": { "const": "canto-span-construction-adjudications-v1" },
    "adjudicated_on": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "adjudication_authority": { "type": "string", "minLength": 1 },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "construction_uuid",
          "construction_code",
          "legacy_label",
          "approved_canonical_name",
          "claim_layer",
          "family_name",
          "profile_name",
          "profile_description",
          "behavior_research_alignment",
          "terminology_alignment",
          "recommended_action",
          "status_recommendation",
          "record_revision",
          "evidence_basis",
          "source_terms",
          "rationale",
          "unresolved_blockers"
        ],
        "properties": {
          "construction_uuid": { "type": "string", "format": "uuid" },
          "construction_code": { "type": "string", "pattern": "^[A-Z]{2}[0-9]{2}$" },
          "legacy_label": { "type": "string", "minLength": 1 },
          "approved_canonical_name": { "type": "string", "minLength": 1 },
          "claim_layer": {
            "enum": ["language_construction", "parser_representation", "compatibility_alias", "diagnostic_state", "unresolved"]
          },
          "family_name": { "type": ["string", "null"] },
          "profile_name": { "type": ["string", "null"] },
          "profile_description": { "type": "string", "minLength": 1 },
          "learner_label": { "type": ["string", "null"] },
          "behavior_research_alignment": {
            "enum": ["exact", "runtime_narrower_defensible", "runtime_broader", "overlapping", "disjoint", "unresolved"]
          },
          "terminology_alignment": {
            "enum": ["aligned", "neutral_descriptive_preferred", "theory_loaded", "misleading", "unresolved"]
          },
          "recommended_action": {
            "enum": ["retain", "retain_narrow", "rename_retain_narrow", "decompose", "internalize_and_decompose", "split", "merge", "supersede", "keep_retired", "reopen_research"]
          },
          "status_recommendation": { "type": "string", "minLength": 1 },
          "record_revision": { "type": "integer", "minimum": 2 },
          "evidence_basis": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_ids", "runtime_locations", "test_file"],
            "properties": {
              "source_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
              "runtime_locations": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
              "test_file": { "type": "string" },
              "additional_research": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
            }
          },
          "source_terms": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["term", "source_id", "scope_match"],
              "properties": {
                "term": { "type": "string", "minLength": 1 },
                "source_id": { "type": "string", "minLength": 1 },
                "scope_match": { "enum": ["exact", "close", "partial", "contrastive"] }
              }
            }
          },
          "former_names": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "successor_profiles": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "rationale": { "type": "string", "minLength": 1 },
          "unresolved_blockers": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
        }
      }
    }
  }
}
